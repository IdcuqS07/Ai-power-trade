# ============================================
# AI Trading Platform - Environment Variables
# ============================================

# ============ BINANCE CONFIGURATION ============
# Mode: 'testnet' or 'production'
BINANCE_MODE=testnet

# Binance Testnet Credentials (for testing)
# Get from: https://testnet.binance.vision/
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_secret_here

# Binance Production Credentials (for live trading)
# WARNING: Only use in production with real funds!
BINANCE_API_KEY=your_production_api_key_here
BINANCE_SECRET=your_production_secret_here

# ============ WEEX CONFIGURATION ============
# WEEX Exchange API Credentials (optional)
# Get from: https://www.weex.com/
WEEX_API_KEY=your_weex_api_key_here
WEEX_SECRET_KEY=your_weex_secret_key_here

# ============ BLOCKCHAIN CONFIGURATION ============
# Polygon Amoy Testnet Configuration
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
POLYGON_CHAIN_ID=80002
CONTRACT_ADDRESS=0xA2E0F4A542b700f437c27Ce28B31499023d9a53A

# Wallet Configuration (for contract interaction)
# WARNING: Never commit real private keys!
OWNER_PRIVATE_KEY=your_private_key_here

# Polygon Explorer
POLYGON_EXPLORER=https://amoy.polygonscan.com/

# ============ APPLICATION CONFIGURATION ============
# Server Configuration
PORT=8000
HOST=0.0.0.0

# Environment
ENVIRONMENT=development

# ============ SOSOVALUE CONFIGURATION ============
# Buildathon / SoSoValue API credentials
ENABLE_SOSOVALUE=true
SOSO_API_KEY=your_sosovalue_api_key_here
SOSO_BASE_URL=https://openapi.sosovalue.com
SOSO_TIMEOUT_SECONDS=15

# ============ OPENROUTER CONFIGURATION ============
# Optional target LLM layer for AI signal reasoning
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=20

# ============ CRYPTOPANIC CONFIGURATION ============
# Optional target provider for news sentiment
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here
CRYPTOPANIC_BASE_URL=https://cryptopanic.com/api/v1
CRYPTOPANIC_TIMEOUT_SECONDS=12

# ============ SODEX CONFIGURATION ============
# Optional target provider for trade execution and fill history
# Spot testnet example. Perps testnet alternative:
# https://testnet-gw.sodex.dev/api/v1/perps
SODEX_API_URL=https://testnet-gw.sodex.dev/api/v1/spot
SODEX_API_KEY=your_sodex_api_key_here
SODEX_API_SECRET=your_sodex_api_secret_here
SODEX_ACCOUNT_ID=your_sodex_account_id_here
SODEX_TIMEOUT_SECONDS=12
SODEX_SIGNING_CHAIN_NAME=ValueChain Testnet
SODEX_SIGNING_RPC_URL=
SODEX_SIGNING_EXPLORER_URL=
SODEX_SIGNING_NATIVE_SYMBOL=SOSO

# ============ EXPLORER / INDEXING CONFIGURATION ============
# Use an Etherscan-compatible explorer key for the active chain
ETHERSCAN_API_KEY=your_etherscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
THE_GRAPH_URL=your_the_graph_subgraph_url_here

# CORS (Frontend URL)
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ============ RISK MANAGEMENT ============
# Maximum position size (as percentage of balance, 0.2 = 20%)
MAX_POSITION_SIZE=0.2

# Minimum confidence score for trades (0-100)
MIN_CONFIDENCE=65

# Maximum daily loss (as percentage, 0.05 = 5%)
MAX_DAILY_LOSS=0.05

# Maximum number of trades per day
MAX_DAILY_TRADES=50

# ============ DATABASE ============
# Optional: Database URL for persistent storage
DATABASE_URL=your_database_url_if_needed

# ============ LOGGING ============
LOG_LEVEL=INFO

# ============ NOTES ============
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env file to version control
# 3. For deployment, set these as environment variables in your hosting platform
# 4. Start with testnet mode for safe testing
# 5. Only use production mode when you're ready for real trading
