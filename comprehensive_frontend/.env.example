# ============================================
# AI Trading Platform - Frontend Environment
# ============================================

# Backend API URL
# Development: http://localhost:8000
# Production: Your deployed backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (optional - defaults to API_URL)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ============ POLYGON AMOY TESTNET ============
# Blockchain Configuration
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_CONTRACT_ADDRESS=0xA2E0F4A542b700f437c27Ce28B31499023d9a53A
NEXT_PUBLIC_RPC_URL=https://rpc-amoy.polygon.technology/
NEXT_PUBLIC_EXPLORER_URL=https://amoy.polygonscan.com/

# Network Details
NEXT_PUBLIC_NETWORK_NAME=Polygon Amoy Testnet
NEXT_PUBLIC_CURRENCY_SYMBOL=MATIC
NEXT_PUBLIC_TOKEN_SYMBOL=atUSDT
NEXT_PUBLIC_TOKEN_NAME=AI Trade USDT

# ============ NOTES ============
# 1. Copy this file to .env.local for local development
# 2. For deployment (Vercel/Netlify), set these in platform settings
# 3. All variables starting with NEXT_PUBLIC_ are exposed to the browser
# 4. Update NEXT_PUBLIC_API_URL to your deployed backend URL
# 5. Get testnet MATIC from: https://faucet.polygon.technology/
